# Copy to scripts/config.env and fill in (config.env is gitignored)

# --- Google Sheets (Phase 2) ---
# Sheet ID from the URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=

# Path to service account JSON (share the sheet with client_email from the JSON)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Tab names (must match your spreadsheet tabs)
SHEET_TAB_MARINES=Marines
SHEET_TAB_COMPANY_MENTORS=Company Mentors

# --- Notifications (Phase 3) ---
# Webhook URL when data changes significantly (examples below)
# ntfy: https://ntfy.sh/your-mardet-topic
# Slack incoming webhook: https://hooks.slack.com/services/...
# Pushover: https://api.pushover.net/1/messages.json (use script extension if needed)
NOTIFY_WEBHOOK_URL=

# Set to 1 to skip notifications even when data changed
SKIP_NOTIFY=0
